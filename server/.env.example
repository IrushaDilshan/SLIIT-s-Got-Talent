# Environment Configuration for Judge Panel Backend

# MongoDB
MONGO_URI=mongodb://localhost:27017/sliit-talent
# For MongoDB Atlas, use:
# MONGO_URI=mongodb+srv://username:password@cluster-name.mongodb.net/sliit-talent

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production_12345678

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@sliit-talent.com

# API Settings
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Judge Panel Settings
JUDGE_SCORING_ENABLED=true
MAX_SCORE_PER_CRITERIA=25
TOTAL_SCORE_MAX=100
